{
  "id": null,
  "uid": "llm-observatory",
  "title": "LLM Observatory",
  "tags": ["llm", "opentelemetry"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(traces_span_metrics_calls_total[$__range]))",
          "legendFormat": "requests",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Input Tokens",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name = \"llm-otel-sidecar\" } | sum_over_time(span.gen_ai.usage.input_tokens)",
          "legendFormat": "input tokens",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Output Tokens",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name = \"llm-otel-sidecar\" } | sum_over_time(span.gen_ai.usage.output_tokens)",
          "legendFormat": "output tokens",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(traces_span_metrics_calls_total[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Usage / Hour",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name = \"llm-otel-sidecar\" } | sum_over_time(span.gen_ai.usage.input_tokens)",
          "legendFormat": "Input Tokens",
          "refId": "A"
        },
        {
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name = \"llm-otel-sidecar\" } | sum_over_time(span.gen_ai.usage.output_tokens)",
          "legendFormat": "Output Tokens",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": { "mode": "normal" },
            "fillOpacity": 30
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Requests / Minute",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_span_metrics_calls_total[1m])) * 60",
          "legendFormat": "req/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "x": 0, "y": 12, "w": 10, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(traces_span_metrics_duration_milliseconds_bucket[5m])) by (le)) / 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Requests by Model",
      "gridPos": { "x": 10, "y": 12, "w": 7, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sort_desc(sum by (gen_ai_request_model) (increase(traces_span_metrics_calls_total[$__range])))",
          "legendFormat": "{{ gen_ai_request_model }}",
          "refId": "A"
        }
      ],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Finish Reasons",
      "gridPos": { "x": 17, "y": 12, "w": 7, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (gen_ai_response_finish_reasons) (increase(traces_span_metrics_calls_total[$__range]))",
          "legendFormat": "{{ gen_ai_response_finish_reasons }}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "vertical",
        "colorMode": "background"
      }
    },
    {
      "id": 11,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "## Explore Individual Traces\nClick **[Explore → Tempo](http://localhost:3000/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22%7D)** to search and drill into individual LLM call spans with full `gen_ai.*` attributes."
      }
    }
  ]
}
